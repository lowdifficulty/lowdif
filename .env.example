# PostgreSQL (Neon recommended for Vercel) — https://neon.tech
DATABASE_URL="postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require"

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# Marketing site (lowdif.com) — landing + whitepaper + auth
NEXT_PUBLIC_MARKETING_URL="http://localhost:3000"

# Streaming app (app.lowdif.com) — player, uploads, share links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Glitch effects (enabled by default; set false to disable)
NEXT_PUBLIC_GLITCH_ENABLED="true"

# Vercel Blob — auto-set when Blob storage is connected. Required in production for uploads.
BLOB_READ_WRITE_TOKEN=""

# QA only: load demo catalog + test accounts on production DB
# SEED_DEMO_DATA="true"

# Blockchain (leave empty for mock mining until Grapewallet is connected)
GRAPEWALLET_API_URL=""
GRAPEWALLET_API_KEY=""
LOWDIF_TOKEN_SYMBOL="LOWDIF"
LOWDIF_TOKENS_PER_LISTEN="1"
