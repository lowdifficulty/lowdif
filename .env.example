# Production uses Neon PostgreSQL (required for Vercel deploy).
# Get a free connection string at https://neon.tech
DATABASE_URL="postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require"

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MARKETING_URL="https://lowdif.com"

# Optional square ad video shown during minting (MP4 URL)
NEXT_PUBLIC_AD_VIDEO_URL=""

# Auto-set on Vercel when you add Blob storage. Leave empty for local dev.
BLOB_READ_WRITE_TOKEN=""

GRAPEWALLET_API_URL=""
GRAPEWALLET_API_KEY=""
LOWDIF_TOKEN_SYMBOL="LOWDIF"
LOWDIF_TOKENS_PER_LISTEN="1"
