generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LISTENER
  ARTIST
}

enum MiningStatus {
  PENDING
  CONFIRMED
  FAILED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          UserRole       @default(LISTENER)
  walletAddress String?
  bio           String?
  avatarUrl          String?
  giveShareToArtists Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  tracks             Track[]
  listenEvents       ListenEvent[]
  miningRecords      MiningRecord[]
  shares             ShareEvent[]   @relation("UserShares")
  referredById       String?
  referredBy           User?          @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals            User[]         @relation("UserReferrals")
  playlists            Playlist[]
}

model Track {
  id           String        @id @default(cuid())
  title        String
  genre        String
  durationSec  Int           @default(0)
  fileUrl      String
  coverUrl     String?
  playCount    Int           @default(0)
  artistId     String
  artist       User          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  listenEvents ListenEvent[]
  ownership    TrackOwnership[]
  shares       ShareEvent[]
  playlistTracks PlaylistTrack[]

  @@index([title])
  @@index([genre])
  @@index([artistId])
}

model ListenEvent {
  id           String        @id @default(cuid())
  userId       String
  trackId      String
  durationMs   Int
  completed    Boolean       @default(false)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  track        Track         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  miningRecord MiningRecord?
  createdAt    DateTime      @default(now())

  @@index([userId])
  @@index([trackId])
}

model MiningRecord {
  id            String       @id @default(cuid())
  userId        String
  listenEventId String       @unique
  txHash        String
  tokens        Float
  status        MiningStatus @default(CONFIRMED)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listenEvent   ListenEvent  @relation(fields: [listenEventId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@index([userId])
}

model TrackOwnership {
  id            String @id @default(cuid())
  trackId       String
  walletAddress String
  sharePercent  Float
  label         String?
  track         Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
}

model ShareEvent {
  id           String   @id @default(cuid())
  sharerId     String?
  sharer       User?    @relation("UserShares", fields: [sharerId], references: [id], onDelete: SetNull)
  trackId      String?
  track        Track?   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  playlistSlug String?
  channel      String
  createdAt    DateTime @default(now())

  @@index([trackId])
  @@index([playlistSlug])
  @@index([sharerId])
  @@index([createdAt])
}

model Playlist {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  coverUrl    String?
  tracks      PlaylistTrack[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@unique([playlistId, position])
  @@index([playlistId])
}
